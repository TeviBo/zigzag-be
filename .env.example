# ZigZag Microservices Environment Variables
# Copy this file to .env and replace the values with your own.

# ==========================================
# MERCADO PAGO INTEGRATION
# ==========================================
# Get this from your Mercado Pago Developer Dashboard
MP_ACCESS_TOKEN=APP_USR-1234567890-123456-abcdefg1234567890

# ==========================================
# SERVICE URLS (Local Development outside Docker)
# ==========================================
# If you run the services locally without docker-compose, these URLs are used
PRODUCT_SERVICE_URL=http://localhost:8001
CART_SERVICE_URL=http://localhost:8002
ORDER_SERVICE_URL=http://localhost:8003

# ==========================================
# DATABASE URLS (Local Development outside Docker)
# ==========================================
# docker-compose automatically sets DATABASE_URL, but you can override here
PRODUCT_DB_URL=sqlite+aiosqlite:///./product.db
CART_DB_URL=sqlite+aiosqlite:///./cart.db
ORDER_DB_URL=sqlite+aiosqlite:///./order.db
