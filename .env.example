# ZigZag Microservices Environment Variables
# Copy this file to .env and replace the values with your own.
#
# ⚠️ ACTION REQUIRED (Fase 0): los valores reales que tenías en .env
# (MP_ACCESS_TOKEN, GOOGLE_CLIENT_ID) deben ser ROTADOS:
#   - Mercado Pago: https://www.mercadopago.com.ar/developers/panel → Credentials → Renovar
#   - Google OAuth: https://console.cloud.google.com → Credentials → reset client secret
# Rotar invalida los tokens viejos por si alguna vez fueron expuestos.

# ==========================================
# SECURITY — required, no defaults
# ==========================================
# Symmetric secret for signing JWT tokens. Shared by auth_service, order_service, product_service.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_64_RANDOM_BYTES

# Shared secret for service-to-service calls (auth ↔ order ↔ notification).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SERVICE_TOKEN=CHANGE_ME_32_RANDOM_BYTES

# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173

# Frontend URL used in MercadoPago back_urls (must be reachable by the browser)
FRONTEND_URL=http://localhost:5173

# ==========================================
# MERCADO PAGO INTEGRATION
# ==========================================
# Access token from Mercado Pago Developer Dashboard
MP_ACCESS_TOKEN=APP_USR-1234567890-123456-abcdefg1234567890

# Webhook signing secret — required to validate /checkout/webhook payloads.
# Set this in MP Developer Panel → Webhooks → "Secret".
MP_WEBHOOK_SECRET=CHANGE_ME_FROM_MP_DASHBOARD

# ==========================================
# GOOGLE INTEGRATION
# ==========================================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ==========================================
# NOTIFICATION PROVIDERS (optional in dev — services mock if missing)
# ==========================================
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ==========================================
# SERVICE URLS (only used outside docker-compose)
# ==========================================
PRODUCT_SERVICE_URL=http://localhost:8001
CART_SERVICE_URL=http://localhost:8002
ORDER_SERVICE_URL=http://localhost:8003
AUTH_SERVICE_URL=http://localhost:8004
NOTIFICATION_SERVICE_URL=http://localhost:8005

# ==========================================
# DATABASE URLS (only used outside docker-compose)
# ==========================================
DATABASE_URL=postgresql+asyncpg://zigzag:zigzag@localhost:5432/zigzag
